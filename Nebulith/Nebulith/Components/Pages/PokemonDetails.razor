@page "/pokemon/{Name}"
@rendermode InteractiveServer
@using Nebulith.Repositories
@using Nebulith.Models
@using Nebulith.Services
@using MudBlazor

@inject PokemonRepository PokeRepo
@inject PokeApiService PokeApiService

@if (_pokemon == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudPaper Elevation="3" Class="pa-4">
        <MudGrid Justify="Justify.Center">
            <MudItem xs="12" sm="6" Class="d-flex justify-center align-center">
                <MudImage Src="@_pokemon.Sprites.FrontDefault" Alt="@_pokemon.Name" Width="300" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h3" Style="@($"text-transform: capitalize; color: {GetColorForType(_pokemon.Types.FirstOrDefault()?.Type.Name)}")">
                    @_pokemon.Name
                </MudText>
                <MudText Typo="Typo.h5" GutterBottom="true">#@_pokemon.Id.ToString("D3")</MudText>
                
                <MudText Typo="Typo.h6" Class="mt-4"><b>Type</b></MudText>
                <MudStack Row="true">
                    @foreach (var typeInfo in _pokemon.Types)
                    {
                        <MudChip T="string" Style="@($"background-color: {GetColorForType(typeInfo.Type.Name)}; color: white;")" Size="Size.Large">@typeInfo.Type.Name</MudChip>
                    }
                </MudStack>
                
                <MudText Typo="Typo.h6" Class="mt-4"><b>Height:</b> @((double)_pokemon.Height / 10) m</MudText>
                <MudText Typo="Typo.h6"><b>Weight:</b> @((double)_pokemon.Weight / 10) kg</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_evolutionChain.Any() && _evolutionChain.Count > 1)
    {
        <MudPaper Elevation="3" Class="pa-4 mt-4">
            <MudText Typo="Typo.h5" GutterBottom="true">Evolution Chain</MudText>

            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                @foreach (var (stage, i) in _evolutionChain.Select((value, index) => (value, index)))
                {
                    @* If this is NOT the first Pokemon, display the arrow and trigger text first *@
                    @if (i > 0)
                    {
                        <div class="d-flex flex-column align-center">
                            <MudText Typo="Typo.body2" Style="text-transform: capitalize;">@stage.TriggerText</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                        </div>
                    }

                    @* Then, display the Pokemon's card *@
                    <MudCard Class="text-center" Elevation="0">
                        <a href="/pokemon/@stage.Pokemon.Name">
                            <MudImage Src="@GetPokemonImageUrl(stage.Pokemon.Url)" Alt="@stage.Pokemon.Name" Width="100" />
                        </a>
                        <MudText Style="text-transform: capitalize;">@stage.Pokemon.Name</MudText>
                    </MudCard>
                }
            </MudStack>
        </MudPaper>
    }

    @if (_pokemon.FlavorTexts.Any())
    {
        <MudPaper Elevation="3" Class="pa-4 mt-4">
            <MudText Typo="Typo.h5" GutterBottom="true">Pokédex Entries</MudText>
            
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="SelectedLanguage" Label="Language" Variant="Variant.Outlined">
                        @foreach (var lang in _availableLanguages)
                        {
                            <MudSelectItem T="string" Value="lang">@lang.ToUpper()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="FlavorTextEntry" @bind-Value="_selectedFlavorText" Label="Select Game Version" Variant="Variant.Outlined" 
                               Disabled="@(!FilteredFlavorTexts.Any())" ToStringFunc="@(e => e == null ? "" : e.Version.Name.Replace("-", " ").ToUpper())">
                        @foreach (var entry in FilteredFlavorTexts)
                        {
                            <MudSelectItem T="FlavorTextEntry" Value="entry">
                                <span style="text-transform: capitalize;">@entry.Version.Name</span>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            @if (_selectedFlavorText != null)
            {
                <MudText Typo="Typo.body1" Class="mt-4">
                    @_selectedFlavorText.FlavorText.Replace("\n", " ").Replace("\f", " ")
                </MudText>
            }
        </MudPaper>
    }

    @if (_pokemon.Moves.Any())
    {
        <MudPaper Elevation="3" Class="pa-4 mt-4">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h5">Moves Learned by @_pokemon.Name</MudText>
                <MudSelect T="string" @bind-Value="_selectedVersionGroup" Label="Game Version" Dense="true" Variant="Variant.Outlined" Style="max-width: 250px;" Class="ml-4">
                    @foreach (var version in _availableVersionGroups)
                    {
                        <MudSelectItem T="string" Value="version">@version.Replace("-", " ").ToUpper()</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <MudGrid>
                @* --- Left Column --- *@
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" GutterBottom="true">By Level Up</MudText>
                    <MudTable Items="@LevelUpMoves" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                        <HeaderContent>
                            <MudTh>Lv.</MudTh>
                            <MudTh>Move</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Lv.">@context.Level</MudTd>
                            <MudTd DataLabel="Move">@context.Name.Replace("-", " ")</MudTd>
                        </RowTemplate>
                    </MudTable>

                    @if (EvolutionMoves.Any())
                    {
                        <MudText Typo="Typo.h6" GutterBottom="true" Class="mt-4">By Evolution</MudText>
                        <MudTable Items="@EvolutionMoves" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                            <HeaderContent>
                                <MudTh>Move</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Move">@context.Name.Replace("-", " ")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudItem>

                @* --- Right Column --- *@
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" GutterBottom="true">By TM</MudText>
                    <MudTable Items="@TMMoves" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                        <HeaderContent>
                            <MudTh>Move</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Move">@context.Name.Replace("-", " ")</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
}



@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    private PokemonDetail? _pokemon;
    private List<EvolutionStage> _evolutionChain = new();
    private List<string> _availableLanguages = new();
    private FlavorTextEntry? _selectedFlavorText;
    private List<string> _availableVersionGroups = new();
    private string? _selectedVersionGroup;


    private string _selectedLanguage = "en";
    private string SelectedLanguage
    {
        get => _selectedLanguage;
        set
        {
            _selectedLanguage = value;
            _selectedFlavorText = FilteredFlavorTexts.FirstOrDefault();
        }
    }

    private List<FlavorTextEntry> FilteredFlavorTexts =>
        _pokemon?.FlavorTexts.Where(e => e.Language.Name == _selectedLanguage).ToList() ?? new();

    private class ProcessedMove
    {
        public int Level { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    private IEnumerable<ProcessedMove> GetMovesFor(string learnMethod)
    {
        if (_pokemon == null || _selectedVersionGroup == null)
            return Enumerable.Empty<ProcessedMove>();

        return _pokemon.Moves
            .SelectMany(m => m.VersionGroupDetails
                .Where(vgd => vgd.VersionGroup.Name == _selectedVersionGroup && vgd.MoveLearnMethod.Name == learnMethod)
                .Select(vgd => new ProcessedMove
                {
                    Level = vgd.LevelLearnedAt,
                    Name = m.Move.Name
                }))
            .OrderBy(m => m.Level)
            .ThenBy(m => m.Name)
            .ToList();
    }

    private IEnumerable<ProcessedMove> LevelUpMoves => GetMovesFor("level-up").Where(m => m.Level > 0);
    private IEnumerable<ProcessedMove> TMMoves => GetMovesFor("machine");
    // I also fixed a bug here: evolution moves are learn method "evolution", not level-up at level 0.
    private IEnumerable<ProcessedMove> EvolutionMoves => GetMovesFor("evolution");
    // End of missing section



    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Name))
        {
            _pokemon = null;
            _evolutionChain = new();
            _selectedFlavorText = null;
            _availableLanguages = new(); // Reset the list
            StateHasChanged();

            var pokemonTask = PokeRepo.GetPokemonDetailsAsync(Name);
            var evolutionTask = PokeApiService.GetEvolutionChainAsync(Name);
            await Task.WhenAll(pokemonTask, evolutionTask);

            _pokemon = await pokemonTask;
            _evolutionChain = (await evolutionTask) ?? new();

           
            if (_pokemon != null && _pokemon.FlavorTexts.Any())
            {

                _availableVersionGroups = _pokemon.Moves
                    .SelectMany(m => m.VersionGroupDetails.Select(vgd => vgd.VersionGroup.Name))
                    .Distinct()
                    .OrderBy(s => s)
                    .ToList();
                _selectedVersionGroup = _availableVersionGroups.LastOrDefault(); // Default to the latest game
               
                _availableLanguages = _pokemon.FlavorTexts.Select(e => e.Language.Name).Distinct().OrderBy(l => l).ToList();
                
                // This line sets the default language
                SelectedLanguage = _availableLanguages.Contains("en") ? "en" : _availableLanguages.FirstOrDefault() ?? "";
            }

        }
    }
    
    private string GetPokemonImageUrl(string pokemonUrl)
    {
        var pokemonId = pokemonUrl.TrimEnd('/').Split('/').Last();
        return $"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/{pokemonId}.png";
    }

    private string GetColorForType(string? type) => type?.ToLower() switch
    {
        "fire" => "#EE8130",
        "water" => "#6390F0",
        "grass" => "#7AC74C",
        "electric" => "#F7D02C",
        "poison" => "#A33EA1",
        "bug" => "#A6B91A",
        "flying" => "#A98FF3",
        "normal" => "#A8A77A",
        "ground" => "#E2BF65",
        "rock" => "#B6A136",
        "fighting" => "#C22E28",
        "psychic" => "#F95587",
        "ghost" => "#866db6",
        "ice" => "#96D9D6",
        "dragon" => "#6F35FC",
        "fairy" => "#D685AD",
        _ => "#A8A77A"
    };
}