@page "/pokemon/{Name}"
@rendermode InteractiveServer
@inject PokemonRepository PokeRepo

@using OmniDex.Models
@using MudBlazor
@using OmniDex.Services
@using OmniDex.Repositories
@using MudBlazor.Utilities


@if (_pokemon == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudPaper Elevation="3" Class="pa-4">
        <MudGrid Justify="Justify.Center">
            <MudItem xs="12" sm="6" Class="d-flex justify-center align-center">
                <MudImage Src="@_pokemon.Sprites.FrontDefault" Alt="@_pokemon.Name" Width="300" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h3" Style="@($"text-transform: capitalize; color: {GetColorForType(_pokemon.Types.FirstOrDefault()?.Type.Name)}")">
                    @_pokemon.Name
                </MudText>
                <MudText Typo="Typo.h5" GutterBottom="true">#@_pokemon.Id.ToString("D3")</MudText>
                
                <MudText Typo="Typo.h6" Class="mt-4"><b>Type</b></MudText>
                <MudStack Row="true">
                    @foreach (var typeInfo in _pokemon.Types)
                    {
                        <MudChip T="string" Style="@($"background-color: {GetColorForType(typeInfo.Type.Name)}")"  Size="Size.Large">@typeInfo.Type.Name</MudChip>
                    }
                </MudStack>
                
                <MudText Typo="Typo.h6" Class="mt-4"><b>Height:</b> @((double)_pokemon.Height / 10) m</MudText>
                <MudText Typo="Typo.h6"><b>Weight:</b> @((double)_pokemon.Weight / 10) kg</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_evolutionChain.Any() && _evolutionChain.Count > 1)
    {
        <MudPaper Elevation="3" Class="pa-4 mt-4">
            <MudText Typo="Typo.h5" GutterBottom="true">Evolution Chain</MudText>
            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="2">
                 @for (var i = 0; i < _evolutionChain.Count; i++)
                {
                    var evolution = _evolutionChain[i];
                    <MudCard Class="text-center" Elevation="0">
                        <a href="/pokemon/@evolution.Name">
                            <MudImage Src="@GetPokemonImageUrl(evolution.Url)" Alt="@evolution.Name" Width="100"/>
                        </a>
                        <MudText Style="text-transform: capitalize;">@evolution.Name</MudText>
                    </MudCard>

                    @if (i < _evolutionChain.Count - 1)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                    }
                }
            </MudStack>
        </MudPaper>
    }
}


@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    private PokemonDetail? _pokemon;
    private List<PokemonResult> _evolutionChain = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Name))
        {
            _pokemon = null; // Clear previous data
            _evolutionChain = new();
            StateHasChanged();

            var pokemonTask = PokeRepo.GetPokemonDetailsAsync(Name);
            var evolutionTask = PokeRepo.GetEvolutionChainAsync(Name);
            await Task.WhenAll(pokemonTask, evolutionTask);

            _pokemon = await pokemonTask;
            _evolutionChain = (await evolutionTask) ?? new();
        }
    }
    
    private string GetPokemonImageUrl(string pokemonUrl)
    {
        var pokemonId = pokemonUrl.TrimEnd('/').Split('/').Last();
        return $"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/{pokemonId}.png";
    }

    private string GetColorForType(string? type) => type?.ToLower() switch
    {
        "fire" => "#EE8130",
        "water" => "#6390F0",
        "grass" => "#7AC74C",
        "electric" => "#F7D02C",
        "poison" => "#A33EA1",
        "bug" => "#A6B91A",
        "flying" => "#A98FF3",
        "normal" => "#A8A77A",
        "ground" => "#E2BF65",
        "rock" => "#B6A136",
        "fighting" => "#C22E28",
        "psychic" => "#F95587",
        "ghost" => "#866db6",
        "ice" => "#96D9D6",
        "dragon" => "#F1B46D",
        "fairy" => "#D685AD",
        _ => "",
    };
}