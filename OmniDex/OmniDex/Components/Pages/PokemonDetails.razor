@page "/pokemon/{Name}"
@using OmniDex.Models
@using OmniDex.Services
@inject PokeApiService PokeService

<PageTitle>@(_pokemon?.Name ?? "...")</PageTitle>

@if (_pokemon == null)
{
    <p><em>Loading details... 🔎</em></p>
}
else
{
    <div class="detail-card">
        <h1>@_pokemon.Name.ToUpper()</h1>
        <img src="@_pokemon.Sprites.FrontDefault" alt="@_pokemon.Name" />
        <h3>Details</h3>
        <p><strong>ID:</strong> @_pokemon.Id</p>
        <p><strong>Weight:</strong> @((double)_pokemon.Weight / 10) kg</p>
        <p><strong>Height:</strong> @((double)_pokemon.Height / 10) m</p>
        <div>
            <strong>Types:</strong>
            @foreach (var typeInfo in _pokemon.Types)
            {
                <span class="type-badge @typeInfo.Type.Name">@typeInfo.Type.Name</span>
            }
        </div>
    </div>
}

@if (_evolutionChain.Any() && _evolutionChain.Count > 1)
{
    <div class="evolution-section">
        <h3>Evolution Chain</h3>
        <div class="evolution-chain-container">
            @for (var i = 0; i < _evolutionChain.Count; i++)
            {
                var evolution = _evolutionChain[i];
                <a href="/pokemon/@evolution.Name" class="evolution-stage">
                    <img src="@GetPokemonImageUrl(evolution.Url)" alt="@evolution.Name" />
                    <span>@evolution.Name</span>
                </a>

                @if (i < _evolutionChain.Count - 1)
                {
                    <span class="evolution-arrow">→</span>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    private PokemonDetail? _pokemon;
    private List<PokemonResult> _evolutionChain = new();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Name))
        {
            var pokemonTask = PokeService.GetPokemonDetailsAsync(Name);
            var evolutionTask = PokeService.GetEvolutionChainAsync(Name);

            await Task.WhenAll(pokemonTask, evolutionTask);

            _pokemon = await pokemonTask;
            _evolutionChain = (await evolutionTask) ?? new();
        }

    }
    private string GetPokemonImageUrl(string pokemonUrl)
    {
        var pokemonId = pokemonUrl.TrimEnd('/').Split('/').Last();
        return $"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/{pokemonId}.png";
    }
}
