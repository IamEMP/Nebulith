@page "/pokedex"
@rendermode InteractiveServer
@using OmniDex.Services
@using OmniDex.Models
@inject PokeApiService PokeService

<PageTitle>OmniDex</PageTitle>

<h1>OmniDex</h1>

<input type="text"
       class="search-bar"
       placeholder="Search Pokémon..."
       @bind="searchTerm"
       @bind:event="oninput" />

@if (!_fullPokemonList.Any())
{
    <p><em>Loading Pokémon... ✨</em></p>
}
else
{
    <div class="pokemon-grid">
        @* ✅ FIX 1: Loop over the FilteredPokemon property *@
        @foreach (var pokemon in FilteredPokemon)
        {
            <a href="/pokemon/@pokemon.Name" class="pokemon-link">
            <div class="pokemon-card">
                <img src="@GetPokemonImageUrl(pokemon.Url)" alt="@pokemon.Name" />
                <h4>@pokemon.Name</h4>
            </div>
            </a>
        }
    </div>
}

@code {
    // ✅ FIX 2: Simplify variables to match your service's return type
    private List<PokemonResult> _fullPokemonList = new();
    private string searchTerm = string.Empty;

    private List<PokemonResult> FilteredPokemon
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchTerm))
            {
                return _fullPokemonList;
            }
            
            return _fullPokemonList
                .Where(p => p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _fullPokemonList = await PokeService.GetPokemonListAsync() ?? new List<PokemonResult>();
    }

    private string GetPokemonImageUrl(string pokemonUrl)
    {
        var pokemonId = pokemonUrl.TrimEnd('/').Split('/').Last();
        return $"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/{pokemonId}.png";
    }
}